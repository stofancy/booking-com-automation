    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "archiver": "^7.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stofancy/booking-com-automation.git"
  },
  "bugs": {
    "url": "https://github.com/stofancy/booking-com-automation/issues"
