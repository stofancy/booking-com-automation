{
  "name": "booking-com-automation",
  "version": "1.1.0",
  "description": "OpenClaw skill for automating booking.com hotel searches",
  "main": "index.js",
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "node tests/e2e/booking-search.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/",
    "test:watch": "node --test --watch tests/unit/*.test.js",
    "release": "node scripts/release.js",
    "validate": "node scripts/validate-skill.js",
    "package": "node scripts/package-skill.js"
  },
  "keywords": [
    "openclaw",
    "skill",
    "booking",
    "automation",
    "browser",
    "travel"
